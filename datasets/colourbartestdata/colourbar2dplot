#!/usr/bin/env python3

import sys
import pandas as pd
import matplotlib.pyplot as plt
from matplotlib import cm
from matplotlib.colors import ListedColormap, LinearSegmentedColormap

colour = cm.get_cmap('seismic', 12)

import os

def normal(x,mn,mx):
    return round((x-mn)/(mx - mn),4)

df = pd.read_csv(sys.argv[1])
colour = pd.read_csv(sys.argv[2])
df.merge(colour, left_on='Residue_Number', right_on='Residue_Number')
mn = df['SASA'].min()
mx = df['SASA'].max() 
df['SASA'] = normal(df['SASA'],mn,mx)
fig, ax = plt.subplots(1,1)

x = 'Residue_Number'
y = 'CSP after WT titration (ppm)'

ax.bar(df[x], df[y], color=(colour(df["SASA"])))
ax.set(ylabel=y) 
plt.xticks(rotation=90)
plt.xlabel(x)
plt.tight_layout()
plt.savefig(os.path.splitext(sys.argv[1])[0]+".svg")
